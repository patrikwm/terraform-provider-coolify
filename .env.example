# Terraform Provider for Coolify - Environment Configuration
# Copy this file to .env and fill in your values
# Usage: source .env (or: set -a; source .env; set +a)

# =============================================================================
# Required for Provider
# =============================================================================

# Your Coolify API endpoint (v1)
# Example: https://coolify.example.com/api/v1
COOLIFY_ENDPOINT=

# Your Coolify API token (create in Coolify dashboard with Root Access)
# Settings → API Tokens → Create Token
COOLIFY_TOKEN=

# =============================================================================
# Testing & Development
# =============================================================================

# Enable acceptance tests (requires working Coolify instance)
# Set to 1 to run acceptance tests, 0 or unset for unit tests only
TF_ACC=1

# Terraform logging level (useful for debugging)
# Options: TRACE, DEBUG, INFO, WARN, ERROR
# Uncomment to enable:
# TF_LOG=DEBUG

# Terraform log file (optional)
# TF_LOG_PATH=./terraform.log

# =============================================================================
# Advanced Configuration
# =============================================================================

# Custom timeout for Terraform operations (seconds)
# TF_TIMEOUT=300

# Provider namespace and host (for OpenTofu testing)
# TF_ACC_PROVIDER_NAMESPACE=hashicorp
# TF_ACC_PROVIDER_HOST=registry.opentofu.org

# Custom Terraform binary path (for testing with specific versions)
# TF_ACC_TERRAFORM_PATH=/usr/local/bin/terraform

# =============================================================================
# CI/CD Secrets (for GitHub Actions - DO NOT commit actual values)
# =============================================================================

# GPG signing (only needed for releases)
# GPG_PRIVATE_KEY=<your-gpg-private-key>
# PASSPHRASE=<your-gpg-passphrase>
# GPG_FINGERPRINT=<your-gpg-fingerprint>

# Code coverage (optional)
# CODECOV_TOKEN=<your-codecov-token>

# =============================================================================
# Example Values (for reference)
# =============================================================================

# COOLIFY_ENDPOINT=https://coolify.local.lan/api/v1
# COOLIFY_TOKEN=eyJ0eXAiOiJKV1QiLC...
# TF_LOG=DEBUG

